{
  "name": "@tdavidson/fund-economics-tool",
  "version": "0.4.0",
  "description": "Aggregate fund economics model — inputs → TVPI/DPI/IRR using a power-law return-tier structure. TypeScript port of the Hemrock Fund Economics Tool.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Taylor Davidson",
  "homepage": "https://github.com/tdavidson/fund-economics-tool",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tdavidson/fund-economics-tool.git"
  },
  "bugs": {
    "url": "https://github.com/tdavidson/fund-economics-tool/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./mc": {
      "types": "./dist/mc.d.ts",
      "import": "./dist/mc.js"
    },
    "./tailwind.preset": "./tailwind.preset.cjs"
  },
  "files": [
    "dist",
    "tailwind.preset.cjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "recharts": ">=2"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "recharts": "^2.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "venture-capital",
    "fund-economics",
    "financial-modeling",
    "tvpi",
    "dpi",
    "irr",
    "hemrock",
    "foresight"
  ]
}
